<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ title | e }}</title>
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<style>{{ css | safe }}</style>
</head>
<body>
  <div class="page-shell">
    <header class="hero">
      <div class="hero-copy">
        <p class="eyebrow">China Convertible Bond Panorama</p>
        <h1>{{ view_model.hero.title | e }}</h1>
        <p class="hero-date">数据截至 {{ view_model.hero.trade_date | e }}</p>
        {% if view_model.hero.summary_lead %}
        <div class="summary-strip">
          {% for line in view_model.hero.summary_lead %}
          <span class="summary-pill">{{ line | e }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <div class="hero-kpis">
        <article class="metric-card">
          <span class="metric-label">总样本</span>
          <strong class="metric-value">{{ view_model.kpis.total }}</strong>
          <span class="metric-foot">只可转债</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">均价</span>
          <strong class="metric-value">{{ "%.1f"|format(view_model.kpis.avg_price) }}</strong>
          <span class="metric-foot">元</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">中位转股溢价</span>
          <strong class="metric-value">{{ "%.1f"|format(view_model.kpis.median_conv) }}%</strong>
          <span class="metric-foot">偏股性温度</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">中位相对价值</span>
          <strong class="metric-value {% if view_model.kpis.median_rv < 1.0 %}is-positive{% elif view_model.kpis.median_rv > 1.2 %}is-negative{% endif %}">{{ "%.2f"|format(view_model.kpis.median_rv) }}</strong>
          <span class="metric-foot">BS 理论定价</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">低估数</span>
          <strong class="metric-value is-positive">{{ view_model.kpis.undervalued }}</strong>
          <span class="metric-foot">RV &lt; 1.0</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">分域分布</span>
          <strong class="metric-value metric-inline">{{ view_model.kpis.n_equity }} / {{ view_model.kpis.n_balanced }} / {{ view_model.kpis.n_debt }}</strong>
          <span class="metric-foot">偏股 / 平衡 / 偏债</span>
        </article>
      </div>
    </header>

    <main class="main-layout">
      <section class="panel market-radar" id="marketRadar">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Market Radar</p>
            <h2>市场雷达</h2>
          </div>
          <p class="section-note">用一张图先看价格、转股溢价与相对价值，再决定深入哪一只。</p>
        </div>
        <div class="market-grid">
          <div class="chart-panel">
            <div class="chart-head">
              <div>
                <h3>价格 × 转股溢价散点</h3>
                <p>气泡大小代表余额，颜色代表相对价值状态。点击标的可直接打开详情。</p>
              </div>
              <div class="legend-row">
                <span class="legend-dot legend-good"></span><span>低估</span>
                <span class="legend-dot legend-neutral"></span><span>合理</span>
                <span class="legend-dot legend-risk"></span><span>偏贵</span>
              </div>
            </div>
            <div id="marketRadarChart" class="chart-stage"></div>
          </div>
          <div class="market-side">
            <article class="side-panel">
              <div class="side-panel-head">
                <h3>今日重点</h3>
                <span>按相对价值优先</span>
              </div>
              <div class="highlight-list">
                {% for item in view_model.highlights %}
                <button class="highlight-item" type="button" data-open-code="{{ item.bond_code | e }}">
                  <span class="highlight-label">{{ item.label | e }}</span>
                  <strong>{{ item.bond_name | e }}</strong>
                  <span>{{ item.theme_group | e }} · RV {{ item.rv | e }}</span>
                </button>
                {% endfor %}
              </div>
            </article>
          </div>
        </div>
      </section>

      {% if view_model.strategy_panels %}
      <section class="panel strategy-deck" id="strategyDeck">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Strategy Deck</p>
            <h2>策略观察</h2>
          </div>
          <p class="section-note">把策略榜单做成可快速扫读的面板，而不是一串长表。</p>
        </div>
        <div class="strategy-grid">
          {% for panel in view_model.strategy_panels %}
          <article class="strategy-card">
            <div class="strategy-head">
              <div>
                <h3>{{ panel.icon | e }}</h3>
                <strong>{{ panel.name | e }}</strong>
              </div>
              <p>{{ panel.desc | e }}</p>
            </div>
            <table class="strategy-table">
              <thead>
                <tr>
                  <th>排名</th>
                  <th>转债</th>
                  <th>价格</th>
                  <th>溢价</th>
                  <th>得分</th>
                </tr>
              </thead>
              <tbody>
                {% for row in panel.rows[:10] %}
                <tr>
                  <td>#{{ row[0] | e }}</td>
                  <td>{{ row[1] | e }}</td>
                  <td>{{ row[3] | e }}</td>
                  <td>{{ row[4] | e }}</td>
                  <td>{{ row[7] | e }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </article>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if view_model.backtest %}
      <section class="panel backtest-panel" id="backtestPanel">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Backtest</p>
            <h2>策略回测</h2>
          </div>
          <p class="section-note">用于判断策略在最近区间内有没有真的跑出来。</p>
        </div>
        <div class="backtest-summary">
          <span>{{ view_model.backtest.summary.start_date | e }} 至 {{ view_model.backtest.summary.end_date | e }}</span>
          <span>{{ view_model.backtest.summary.trading_days }} 个交易日</span>
          <span>{{ view_model.backtest.summary.n_rebalances }} 次调仓</span>
        </div>
        <div class="backtest-returns">
          {% set curves = [
            ("双低 Top10", "dl"),
            ("偏股双低", "equity"),
            ("平衡双低", "balanced"),
            ("偏债双低", "debt"),
            ("低估 Top10", "rv"),
            ("中证转债", "bench"),
          ] %}
          {% for label, key in curves %}
          {% set cum = view_model.backtest.summary["cum_return_" ~ key ~ "_pct"] | default(0) %}
          {% set ann = view_model.backtest.summary["annualized_" ~ key ~ "_pct"] | default(0) %}
          {% set sharpe = view_model.backtest.summary["sharpe_" ~ key] | default(0) %}
          {% set mdd = view_model.backtest.summary["max_drawdown_" ~ key ~ "_pct"] | default(0) %}
          <div class="backtest-return-card">
            <span class="backtest-label">{{ label }}</span>
            <strong class="backtest-value {% if cum > 0 %}is-positive{% elif cum < 0 %}is-negative{% endif %}">{{ "%.2f"|format(cum) }}%</strong>
            <span class="backtest-foot">年化 {{ "%.1f"|format(ann) }}% · Sharpe {{ "%.2f"|format(sharpe) }} · 回撤 {{ "%.1f"|format(mdd) }}%</span>
          </div>
          {% endfor %}
        </div>
        <div id="equityChart" class="chart-stage chart-stage-lg"></div>
      </section>
      {% endif %}

      <section class="panel explorer-workbench" id="explorerWorkbench">
        <div class="section-heading section-heading-split">
          <div>
            <p class="section-kicker">Explorer</p>
            <h2>标的工作台</h2>
          </div>
          <div class="view-switch" role="tablist" aria-label="切换视图">
            <button type="button" class="view-btn is-active" data-view="cards">卡片视图</button>
            <button type="button" class="view-btn" data-view="table">数据表</button>
          </div>
        </div>

        <div class="toolbar">
          <label class="field search-field">
            <span>搜索</span>
            <input id="searchInput" type="search" placeholder="转债 / 正股 / 代码 / 题材 / 业务描述">
          </label>
          <label class="field">
            <span>题材</span>
            <select id="themeFilter">
              <option value="">全部题材</option>
              {% for theme in view_model.explorer.theme_options %}
              <option value="{{ theme | e }}">{{ theme | e }}</option>
              {% endfor %}
            </select>
          </label>
          <label class="field">
            <span>分类</span>
            <select id="categoryFilter">
              <option value="">全部分类</option>
              {% for group in view_model.explorer.groups %}
              <option value="{{ group.category | e }}">{{ group.category | e }}</option>
              {% endfor %}
            </select>
          </label>
          <div class="toolbar-actions">
            <button class="toolbar-btn" id="copyCodes" type="button">复制代码</button>
            <button class="toolbar-btn" id="exportCsv" type="button">导出 CSV</button>
          </div>
        </div>

        <div class="quick-row">
          <button class="quick-chip is-active" type="button" data-quick="all">全部</button>
          <button class="quick-chip" type="button" data-quick="undervalued">低估</button>
          <button class="quick-chip" type="button" data-quick="lowPremium">低溢价</button>
          <button class="quick-chip" type="button" data-quick="highDelta">高 Delta</button>
          <button class="quick-chip" type="button" data-quick="callRisk">强赎触发</button>
          <button class="quick-chip" type="button" data-quick="lowPrice">百元以下</button>
        </div>

        <div class="result-bar">
          <div>
            当前命中 <strong id="resultCount">{{ view_model.kpis.total }}</strong> 只
            <span id="activeSummary">全部标的</span>
          </div>
          <span id="exportStatus" class="status-text"></span>
        </div>

        <div class="explorer-body">
          <div id="cardsView" class="cards-view"></div>
          <div id="tableView" class="table-view" hidden>
            <table class="bond-table">
              <thead>
                <tr>
                  <th data-sort-key="bond_name">转债</th>
                  <th data-sort-key="price">价格</th>
                  <th data-sort-key="conv">转股溢价</th>
                  <th data-sort-key="relative_value">相对价值</th>
                  <th data-sort-key="delta">Delta</th>
                  <th data-sort-key="balance">余额(亿)</th>
                  <th data-sort-key="theme_group">主题</th>
                  <th>状态</th>
                </tr>
              </thead>
              <tbody id="tableBody"></tbody>
            </table>
          </div>
          <div id="emptyState" class="empty-state" hidden>
            <h3>没有符合当前条件的标的</h3>
            <p>试试清空筛选，或者切到其他题材与分类。</p>
          </div>
        </div>
      </section>
    </main>

    {% if view_model.appendix %}
    <footer class="footer">
      <h2>附录 · 字段说明</h2>
      <ul>
        {% for line in view_model.appendix %}
        <li>{{ line | e }}</li>
        {% endfor %}
      </ul>
    </footer>
    {% endif %}
  </div>

  <div class="drawer-scrim" id="drawerScrim" hidden></div>
  <aside class="detail-drawer" id="detailDrawer" aria-hidden="true">
    <button class="drawer-close" id="detailClose" type="button">关闭</button>
    <div id="detailContent"></div>
  </aside>

  <script>
  window.__VIEW_MODEL__ = {{ view_model_json | safe }};
  {{ js | safe }}
  </script>
</body>
</html>
